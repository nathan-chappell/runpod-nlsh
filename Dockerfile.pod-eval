# syntax=docker/dockerfile:1

ARG RUNPOD_BASE_IMAGE=runpod/pytorch:1.0.3-cu1281-torch291-ubuntu2404
FROM ${RUNPOD_BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive \
    CC=/usr/bin/gcc \
    CXX=/usr/bin/g++ \
    HF_HOME=/workspace/hf-cache \
    TMPDIR=/workspace/tmp \
    TRANSFORMERS_CACHE=/workspace/hf-cache \
    TRITON_CACHE_DIR=/workspace/triton-cache \
    VLLM_CACHE_ROOT=/workspace/vllm-cache \
    XDG_CACHE_HOME=/workspace/.cache \
    NLSH_VLLM_LIKE=1 \
    POD_EVAL_VENV=/workspace/nlsh-venv \
    PIP_NO_CACHE_DIR=1 \
    PYTHONUNBUFFERED=1

WORKDIR /opt/nlsh

COPY pyproject.toml README.md ./
COPY src ./src
COPY data ./data
COPY configs ./configs
COPY scripts ./scripts

RUN mkdir -p /workspace/hf-cache /workspace/tmp /workspace/triton-cache /workspace/vllm-cache /workspace/.cache \
    && chmod 1777 /workspace/tmp \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        build-essential \
        ca-certificates \
        curl \
        findutils \
        git \
        iproute2 \
        jq \
        libgomp1 \
        libnuma1 \
        openssh-client \
        openssh-server \
        procps \
        python-is-python3 \
        python3-dev \
        python3-venv \
        qpdf \
    && rm -rf /var/lib/apt/lists/* \
    && chmod +x scripts/pod_eval.py scripts/runpod_bootstrap.py

ENTRYPOINT []
CMD ["python", "scripts/runpod_bootstrap.py"]
